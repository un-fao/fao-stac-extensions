  "id": "ASI-D",
  "title": "Agricultural Stress Index — Dekadal — Global 1km",
  "description": "Agricultural Stress Index (ASI) — Dekadal product. ASI depicts the percentage of arable land within an administrative area that has been affected by drought conditions from the start of the season up to the current dekad. This example illustrates the FAO ISO 19115-1 STAC profile end-to-end: it carries fao:* identifiers, iso:* metadata fields, and fields contributed by the standard extensions listed in stac_extensions.",
  "license": "CC-BY-4.0",
  "language": {"code": "en", "name": "English"},
  "keywords": [
    "Agricultural Stress Index",
    "Drought",
    "Crop monitoring",
    "Vegetation Health",
    "Dekadal"
  ],
  "providers": [
    {
      "name": "FAO Global Information and Early Warning System",
      "description": "Producer and metadata point of contact (giews1@example.org).",
      "roles": ["producer", "host"]
    }
  ],
  "extent": {
    "spatial": {"bbox": [[-180.0, -56.0, 180.0, 75.0]]},
    "temporal": {"interval": [[ "1984-01-01T00:00:00Z", null ]]}
  },
  "themes": [
    {
      "scheme": "https://www.isotc211.org/2005/resources/Codelist/gmxCodelists.xml#MD_TopicCategoryCode",
      "concepts": [
        {"id": "farming", "title": "Farming"},
        {"id": "biota", "title": "Biota"}
      ]
    }
  ],
  "sci:citation": "FAO GIEWS, Agricultural Stress Index (ASI) — Dekadal product. https://example.org/cite/asi-d",
  "fao:workspace": "ASIS",
  "fao:product_id": "ASI-D",
  "fao:layer_id": "ASIS.ASI-D",
  "fao:product_type": "mapset",
  "iso:lineage_statement": "ASI is computed by integrating the Vegetation Health Index (VHI) over time and space using crop phenology and crop mask layers; values below the VHI=35 threshold are accumulated per administrative area to produce the percentage of stressed arable land.",
  "iso:maintenance_and_update_frequency": "asNeeded",
  "iso:spatial_representation_type": "grid",
  "iso:status": "onGoing",
  "iso:purpose": "Early identification of cropped land likely to be under water stress, supporting near-real-time agricultural drought monitoring.",
  "iso:character_set_code": "utf8",
  "iso:presentation_form": "mapDigital",
  "iso:access_constraints": "license",
  "iso:use_constraints": "license",
  "iso:use_limitation": "Attribution required per CC-BY-4.0; no warranty of fitness for any particular purpose.",
  "cube:dimensions": {
    "x": {"type": "spatial", "axis": "x", "extent": [-180.0, 180.0], "reference_system": 4326, "description": "Longitude (WGS84)"},
    "y": {"type": "spatial", "axis": "y", "extent": [-90.0, 90.0], "reference_system": 4326, "description": "Latitude (WGS84)"},
    "time": {"type": "temporal", "extent": ["1984-01-01T00:00:00Z", null], "step": "P10D", "description": "Dekad"},
    "SEASON": {"type": "categorical", "values": ["GS1", "GS2"], "description": "Growing Season"},
    "LCT": {"type": "categorical", "values": ["LC-C", "LC-G"], "description": "Land Cover Type"}
  },
  "cube:variables": {
    "asi-d": {
      "type": "data",
      "dimensions": ["x", "y", "time", "SEASON", "LCT"],
      "description": "Agricultural Stress Index",
      "unit": "%",
      "nodata": 255,
      "data_type": "float32"
    }
  },
  "renders": {
    "data": {
      "title": "Agricultural Stress Index",
      "assets": ["data"],
      "colormap_name": "ASI-D-G",
      "resampling": "nearest"
    }
  },
  "summaries": {
    "fao:workspace": ["ASIS"],
    "fao:product_id": ["ASI-D"],
    "datetime": {
